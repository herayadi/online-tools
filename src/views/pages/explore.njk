{% extends "layouts/listing.njk" %}

{% block listing_content %}
<div class="explore-header">
  <h2>Explore Tools</h2>
  <div class="search-box large search-container">
    <input type="text" id="explore-search-input" class="search-input" placeholder="Search by name, tag, or keyword..." autocomplete="off" />
  </div>
</div>

<div class="explore-layout">
  <aside class="explore-sidebar">
    <div class="filter-group">
      <h3>Categories</h3>
      <div id="category-filters" class="filter-list">
        <button class="filter-btn active" data-category="all">All Categories</button>
        {% for cat in categories %}
        <button class="filter-btn" data-category="{{ cat.id }}">{{ cat.title }}</button>
        {% endfor %}
      </div>
    </div>
    
    <div class="filter-group" id="subcategory-filters-container" style="display: none;">
      <h3>Subcategories</h3>
      <div id="subcategory-filters" class="filter-list">
        <!-- Injected via JS based on selected category -->
      </div>
    </div>
  </aside>

  <div class="explore-main">
    <div id="search-results-meta" class="results-meta"></div>
    <div class="explore-grid" id="search-results">
      <!-- Injected via JS -->
    </div>
    
    {% include "partials/empty-state.njk" %}
  </div>
</div>

<!-- Template for JS rendering (fallback) -->
<template id="tool-card-template">
  <div class="tool-card-wrapper">
    <a href="" class="tool-card">
      <div class="tool-icon">
        <img src="" alt="" onerror="if(!this.dataset.f){this.dataset.f=1;this.src='{{ asset('images/logo.svg') }}';}else{this.style.display='none';}" />
      </div>
      <div class="tool-info">
        <h3></h3>
        <p></p>
      </div>
    </a>
    <div class="card-actions">
      <button class="btn-compare card-compare" data-tool-id="" aria-label="Toggle Compare" title="Compare">
        <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><path d="M9 18l6-6-6-6"/></svg>
      </button>
      <button class="btn-favorite card-favorite" data-tool-id="" aria-label="Toggle Favorite">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
      </button>
    </div>
  </div>
</template>
{% endblock %}

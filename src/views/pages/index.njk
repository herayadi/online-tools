{% extends "layouts/listing.njk" %}

{% block listing_content %}
<div class="hero search-first-hero">
  <h2>Welcome to Online Tools</h2>
  <p>{{ site.description }}</p>
  <div class="search-box large search-container">
    <input type="text" id="global-search" class="search-input" placeholder="Search for tools (e.g. md5, json, format)..." autocomplete="off" />
    <div id="search-suggestions" class="search-suggestions dropdown-menu" style="display: none;"></div>
  </div>
  <div class="hero-quick-links">
    <a href="{{ asset('explore/') }}">Browse All Tools &rarr;</a>
  </div>
</div>

<!-- Personalization Sections (Injected via JS) -->
<div class="popular-section" id="home-favorites-section" style="display: none;">
  <h3>Your Favorites</h3>
  <div class="explore-grid" id="home-favorites-grid"></div>
</div>

<div class="popular-section" id="home-history-section" style="display: none;">
  <h3>Recently Used</h3>
  <div class="explore-grid" id="home-history-grid"></div>
</div>

<div class="popular-section">
  <h3>Popular Tools</h3>
  <div class="explore-grid">
    {% for tool in tools %}
      {% if tool.popular %}
      <div class="tool-card-wrapper">
        <a href="{{ asset(tool.path) }}" class="tool-card">
          <div class="tool-icon">
            <img src="{{ asset('images/icons/' + (tool.icon | default('wrench')) + '.svg') }}" alt="{{ tool.title }}" onerror="if(!this.dataset.f){this.dataset.f=1;this.src='{{ asset('images/logo.svg') }}';}else{this.style.display='none';}" />
          </div>
          <div class="tool-info">
            <h3>{{ tool.title }}</h3>
            <p>{{ tool.shortDescription | default(tool.description) | truncate(60) }}</p>
          </div>
        </a>
        <div class="card-actions">
          <button class="btn-compare card-compare" data-tool-id="{{ tool.id }}" aria-label="Toggle Compare" title="Compare">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><path d="M9 18l6-6-6-6"/></svg>
          </button>
          <button class="btn-favorite card-favorite" data-tool-id="{{ tool.id }}" aria-label="Toggle Favorite">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          </button>
        </div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<div class="collections-section">
  <h3>Curated Collections</h3>
  <div class="collections-grid">
    {% for pack in collections %}
    <div class="collection-card">
      <h4>{{ pack.title }}</h4>
      <p>{{ pack.description }}</p>
      <div class="tools-list">
        {% for toolId in pack.tools %}
          {% set t = toolsById[toolId] %}
          {% if t %}
          <a href="{{ asset(t.path) }}" class="tool-chip">{{ t.title }}</a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</div>

<div class="categories-section">
  <h3>Browse by Category</h3>
  <div class="categories-grid">
    {% for cat in categories %}
    <div class="category-card">
      <h4><a href="{{ asset('explore/?category=' + cat.id) }}">{{ cat.title }}</a></h4>
      <ul>
        {% for sub in cat.subcategories %}
          <li><a href="{{ asset('explore/?category=' + cat.id + '&subcategory=' + sub.id) }}">{{ sub.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
</div>
{% endblock %}

{% extends "layouts/tool.njk" %}
{% import "macros/tool-components.njk" as components with context %}

{% block tool_input %}
  {{ components.panel({
    title: 'Input',
    id: 'input',
    type: 'input',
    placeholder: 'Enter here...',
    copy: false,
    fullscreen: true,
    editor: true,
    editorLang: 'json'
  }) }}
{% endblock %}

{% block tool_output %}
  {{ components.panel({
    title: 'Output',
    id: 'output',
    type: 'output',
    placeholder: 'Output here...',
    readonly: true,
    copy: true,
    fullscreen: true,
    editor: true,
    editorLang: 'json'
  }) }}
{% endblock %}

{% block tool_settings %}
<div class="setting">
  <label for="indent-type">Indent Type</label>
  <select id="indent-type" data-option="indent-type" data-remember="indent-type">
    <option value="space" selected>Space</option>
    <option value="tab">Tab</option>
  </select>
</div>
<div class="setting">
  <label for="indent">Indent</label>
  <input id="indent" type="number" value="2" step="1" min="1" max="10" data-option="indent" data-remember="indent" />
</div>
{% endblock %}
